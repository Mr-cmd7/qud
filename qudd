-- Разбор строк
DECLARE @OrderNumber INT, @ArticleList NVARCHAR(MAX), @OrderDate DATETIME, @DeliveryDate DATETIME,
        @PickupPointId INT, @CustomerFullName NVARCHAR(200), @PickupCode NVARCHAR(50), @OrderStatus NVARCHAR(50),
        @UserLogin NVARCHAR(100), @pos INT, @comma INT, @article NVARCHAR(50), @quantity INT;

DECLARE cur CURSOR FOR
SELECT OrderNumber, ArticleList, OrderDate, DeliveryDate, PickupPointId, CustomerFullName, PickupCode, OrderStatus
FROM #TempOrders;

OPEN cur;
FETCH NEXT FROM cur INTO @OrderNumber, @ArticleList, @OrderDate, @DeliveryDate, @PickupPointId, @CustomerFullName, @PickupCode, @OrderStatus;

WHILE @@FETCH_STATUS = 0
BEGIN
    SELECT @UserLogin = Login FROM Users WHERE FullName = @CustomerFullName;
    IF @UserLogin IS NULL
    BEGIN
        PRINT N'Пользователь не найден: ' + @CustomerFullName;
        FETCH NEXT FROM cur INTO @OrderNumber, @ArticleList, @OrderDate, @DeliveryDate, @PickupPointId, @CustomerFullName, @PickupCode, @OrderStatus;
        CONTINUE;
    END

    SET @ArticleList = @ArticleList + N',';
    SET @pos = 1;
    WHILE @pos < LEN(@ArticleList)
    BEGIN
        SET @comma = CHARINDEX(N',', @ArticleList, @pos);
        IF @comma = 0 BREAK;
        SET @article = LTRIM(RTRIM(SUBSTRING(@ArticleList, @pos, @comma - @pos)));
        SET @pos = @comma + 1;
        SET @comma = CHARINDEX(N',', @ArticleList, @pos);
        IF @comma = 0 BREAK;
        SET @quantity = TRY_CAST(LTRIM(RTRIM(SUBSTRING(@ArticleList, @pos, @comma - @pos))) AS INT);
        IF @quantity IS NULL SET @quantity = 0;
        SET @pos = @comma + 1;

        IF @quantity > 0
        BEGIN
            INSERT INTO Orders (UserLogin, OrderDate, DeliveryDate, PickupPointId, Status, PickupCode, ProductArticle, Quantity)
            VALUES (@UserLogin, @OrderDate, @DeliveryDate, @PickupPointId, @OrderStatus, @PickupCode, @article, @quantity);
        END
    END

    FETCH NEXT FROM cur INTO @OrderNumber, @ArticleList, @OrderDate, @DeliveryDate, @PickupPointId, @CustomerFullName, @PickupCode, @OrderStatus;
END

CLOSE cur;
DEALLOCATE cur;
DROP TABLE #TempOrders;
GO

