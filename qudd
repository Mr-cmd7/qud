-- ==================================================
-- 1. Таблица Users
-- ==================================================
CREATE TABLE Users (
    Login NVARCHAR(100) NOT NULL,
    Role NVARCHAR(50) NOT NULL,
    FullName NVARCHAR(200) NOT NULL,
    Password NVARCHAR(100) NOT NULL,
    CONSTRAINT PK_Users PRIMARY KEY (Login),
    CONSTRAINT CHK_Users_Role CHECK (Role IN (N'Авторизированный клиент', N'Менеджер', N'Администратор'))
);
GO

-- 2. Таблица PickupPoints
CREATE TABLE PickupPoints (
    Id INT IDENTITY(1,1) NOT NULL,
    Address NVARCHAR(500) NOT NULL,
    CONSTRAINT PK_PickupPoints PRIMARY KEY (Id),
    CONSTRAINT UQ_PickupPoints_Address UNIQUE (Address)
);
GO

-- 3. Таблица Products
CREATE TABLE Products (
    Article NVARCHAR(50) NOT NULL,
    Name NVARCHAR(200) NOT NULL,
    Unit NVARCHAR(20) NOT NULL,
    Price DECIMAL(18,2) NOT NULL,
    Category NVARCHAR(100) NOT NULL,
    Manufacturer NVARCHAR(100) NOT NULL,
    Supplier NVARCHAR(100) NOT NULL,
    Discount INT NOT NULL DEFAULT 0,
    Quantity INT NOT NULL DEFAULT 0,
    Description NVARCHAR(MAX) NULL,
    ImagePath NVARCHAR(500) NULL,
    CONSTRAINT PK_Products PRIMARY KEY (Article),
    CONSTRAINT CHK_Products_Price CHECK (Price >= 0),
    CONSTRAINT CHK_Products_Quantity CHECK (Quantity >= 0),
    CONSTRAINT CHK_Products_Discount CHECK (Discount BETWEEN 0 AND 100)
);
GO

-- 4. Таблица Orders
CREATE TABLE Orders (
    Id INT IDENTITY(1,1) NOT NULL,
    UserLogin NVARCHAR(100) NOT NULL,
    OrderDate DATETIME NOT NULL,
    DeliveryDate DATETIME NULL,
    PickupPointId INT NOT NULL,
    Status NVARCHAR(50) NOT NULL,
    PickupCode NVARCHAR(50) NOT NULL,
    ProductArticle NVARCHAR(50) NOT NULL,
    Quantity INT NOT NULL,
    CONSTRAINT PK_Orders PRIMARY KEY (Id),
    CONSTRAINT FK_Orders_Users FOREIGN KEY (UserLogin) REFERENCES Users(Login),
    CONSTRAINT FK_Orders_PickupPoints FOREIGN KEY (PickupPointId) REFERENCES PickupPoints(Id),
    CONSTRAINT FK_Orders_Products FOREIGN KEY (ProductArticle) REFERENCES Products(Article),
    CONSTRAINT CHK_Orders_Quantity CHECK (Quantity > 0)
);
GO

